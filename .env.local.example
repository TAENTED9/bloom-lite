# Prototype uses SQLite (local file) — zero setup, then `npm run db:push`.
# For production, set provider="postgresql" in prisma/schema.prisma and use:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bloom_lite?schema=public"
DATABASE_URL="file:./dev.db"
JWT_SECRET="your-32-char-minimum-secret-here"
ENCRYPTION_KEY="your-32-char-aes-256-key-here"
NEXT_PUBLIC_APP_NAME="Bloom Lite"
NEXT_PUBLIC_APP_ENV="development"
SOLANA_RPC_URL="https://api.devnet.solana.com"
